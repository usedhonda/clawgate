{
  "manifest_version": 3,
  "name": "ClawGate",
  "description": "Send pages to Chi, your AI companion",
  "version": "0.4.3",
  "key": "MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "ClawGate",
    "default_popup": "popup/popup.html"
  },
  "sandbox": {
    "pages": [
      "sandbox/ocr.html"
    ]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sandbox/ocr.html",
        "sandbox/ocr.js",
        "vendor/ocrad.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
